# Flowxiq — Environment Configuration Example
# Copy this to .env (for local development) or .env.local
# NEVER commit raw credential files (.env, .env.local) to Git tracking

# ─── DATABASE (Turso / libSQL) ──────────────────────────────────────────────────
# Required for primary data storage
TURSO_DATABASE_URL=libsql://your-database-name.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token_here

# ─── SECURITY & SESSION (JWT & AES-256) ──────────────────────────────────────────
# JWT secret key for signing session tokens (generate a strong random secret)
JWT_SECRET=your_jwt_signing_secret_here

# 64-character hex string key for AES-256-GCM POS credentials encryption
# Generate with: openssl rand -hex 32
PLATFORM_ENCRYPTION_KEY=your_64_char_hex_encryption_key_here

# ─── RATE LIMITING (Upstash Redis) ──────────────────────────────────────────────
# Required for production brute force protection. Falls back to in-memory in dev/CI.
UPSTASH_REDIS_REST_URL=https://your-redis-name.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token_here

# ─── EMAIL SERVICE (Resend) ─────────────────────────────────────────────────────
# Required for account invitation and password reset flows
RESEND_API_KEY=re_your_resend_api_key_here

# ─── APPLICATION METADATA ───────────────────────────────────────────────────────
# Base URL of the application (no trailing slash)
NEXT_PUBLIC_APP_URL=https://www.flowxiq.com

# ─── LEGACY CONFIGURATION (Optional / Legacy Google Sheets) ─────────────────────
# GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
# GOOGLE_SHEET_ID=your_sheet_id_here
# OWNER_PIN=1234
