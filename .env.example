# Copy this to .env.local and fill in your values
# NEVER commit .env.local to GitHub

# From your Google service account JSON file
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"

# The ID of your Google Sheet (from the URL: /spreadsheets/d/THIS_PART/edit)
GOOGLE_SHEET_ID=your_sheet_id_here

# Owner PIN to access the dashboard
OWNER_PIN=1234

# Must match your Vercel deployment URL (no trailing slash)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
